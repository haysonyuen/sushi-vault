TELLER_APP_ID=app_xxxxxxxxxxxxxxxx
TELLER_ACCESS_TOKENS=token_xxxxxxxx,token_yyyyyyyy
TELLER_CERT_PATH=/path/to/certs/certificate.pem
TELLER_KEY_PATH=/path/to/certs/private_key.pem
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── Email reports ──────────────────────────────────────────────────────────
GMAIL_USER=you@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
# REPORT_TO=           # optional: send to a different address than GMAIL_USER

# ── Google OAuth ────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxx
ALLOWED_EMAILS=you@gmail.com,spouse@gmail.com
APP_URL=http://localhost:3000

# Teller.io (bank data)
TELLER_APP_ID=your_teller_app_id
TELLER_ACCESS_TOKENS=token1,token2
TELLER_CERT_PATH=./certs/certificate.pem
TELLER_KEY_PATH=./certs/private_key.pem

# Claude AI
ANTHROPIC_API_KEY=your_anthropic_api_key

# Email reports
GMAIL_USER=you@gmail.com
GMAIL_APP_PASSWORD=your_gmail_app_password
# REPORT_TO=recipient@email.com

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
ALLOWED_EMAILS=you@gmail.com,spouse@gmail.com
ADMIN_EMAILS=you@gmail.com   # sees all accounts; add your own email here
APP_URL=https://yourdomain.com

# Server
UI_PORT=443
SESSION_SECRET=random_secret_here

# SSL (production only)
SSL_CERT=/etc/letsencrypt/live/yourdomain.com/fullchain.pem
SSL_KEY=/etc/letsencrypt/live/yourdomain.com/privkey.pem
